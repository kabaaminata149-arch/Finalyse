# Finalyse — Configuration (copiez ce fichier en .env et remplissez les valeurs)

JWT_SECRET=changez-cette-valeur-secrete
JWT_EXPIRE_H=24

# Ollama (IA locale)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# DeepSeek API (optionnel — améliore l'extraction)
# Obtenez une clé sur : https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# MongoDB Atlas (sauvegarde cloud — optionnel)
# Obtenez une URI sur : https://www.mongodb.com/atlas (gratuit)
MONGODB_URI=
MONGODB_DB=finalyse

# Email (pour l'envoi de rapports)
# Gmail : activez "Mots de passe d'application" sur myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Limites
MAX_MB=20
